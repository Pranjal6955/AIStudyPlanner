# -----------------------------------------------
# AI Study Planner — Environment Variables
# Copy this file to .env and fill in your values.
# -----------------------------------------------

# Required: Your Groq API key (free at https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Optional: Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Sampling temperature 0-2 (default: 0.7)
GROQ_TEMPERATURE=0.7
